{
  "info": {
    "name": "Mentora Backend API",
    "_postman_id": "mentora-api",
    "description": "Postman collection for Mentora backend assignment",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Signup",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n\"name\":\"John\",\n\"email\":\"john@test.com\",\n\"password\":\"123456\",\n\"role\":\"parent\"\n}"
        },
        "url": {
          "raw": "http://localhost:5000/auth/signup",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["auth", "signup"]
        }
      }
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n\"email\":\"john@test.com\",\n\"password\":\"123456\"\n}"
        },
        "url": {
          "raw": "http://localhost:5000/auth/login",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["auth", "login"]
        }
      }
    },
    {
      "name": "Create Student",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer TOKEN" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n\"name\":\"Alex\",\n\"age\":14\n}"
        },
        "url": {
          "raw": "http://localhost:5000/students",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["students"]
        }
      }
    },
    {
      "name": "Create Lesson",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n\"title\":\"Math Basics\",\n\"description\":\"Intro to Algebra\"\n}"
        },
        "url": {
          "raw": "http://localhost:5000/lessons",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["lessons"]
        }
      }
    }
  ]
}